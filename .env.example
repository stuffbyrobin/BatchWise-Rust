# Required
APP_ENV=development
DATABASE_URL=postgres://batchwise:batchwise@localhost:5432/batchwise?sslmode=disable
JWT_SECRET=replace_me_with_openssl_rand_base64_48

# Optional (defaults shown)
APP_BASE_URL=http://localhost:8080
HTTP_PORT=8080
JWT_ISSUER=batchwise
JWT_AUDIENCE=batchwise
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7
CORS_ORIGIN=http://localhost:5173
ALLOW_OVERDRAFT=false
BOOTSTRAP_REGISTRATION_ENABLED=false
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=600
MIGRATIONS_DISABLED=false
LOG_LEVEL=info

# Generate JWT_SECRET locally with: openssl rand -base64 48

# Tests use the `testcontainers` crate, which needs a Docker/Podman socket.
# Podman users:
#   systemctl --user start podman.socket
#   export DOCKER_HOST=unix:///run/user/$(id -u)/podman/podman.sock
