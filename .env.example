# Required
APP_ENV=development
DATABASE_URL=postgres://batchwise:batchwise@localhost:5432/batchwise?sslmode=disable
JWT_SECRET=replace_me_with_openssl_rand_base64_48

# --- Supabase (managed Postgres) ---------------------------------------------
# Supabase IS Postgres, so only DATABASE_URL changes. TLS is enforced, so keep
# sslmode=require. Find these under Project Settings -> Database. See docs/supabase.md.
#
# Direct connection (port 5432) — recommended for migrations & a single backend:
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
#
# Transaction pooler (port 6543) — for high concurrency / serverless. The app
# disables sqlx statement caching automatically when it sees port 6543:
#   DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Optional (defaults shown)
APP_BASE_URL=http://localhost:8080
HTTP_PORT=8080
JWT_ISSUER=batchwise
JWT_AUDIENCE=batchwise
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7
CORS_ORIGIN=http://localhost:5173
ALLOW_OVERDRAFT=false
BOOTSTRAP_REGISTRATION_ENABLED=false
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REFRESH_PER_MINUTE=30
RATE_LIMIT_DEFAULT_PER_MINUTE=600
MIGRATIONS_DISABLED=false
LOG_LEVEL=info

# Generate JWT_SECRET locally with: openssl rand -base64 48

# Tests use the `testcontainers` crate, which needs a Docker/Podman socket.
# Podman users:
#   systemctl --user start podman.socket
#   export DOCKER_HOST=unix:///run/user/$(id -u)/podman/podman.sock
